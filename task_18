#include <iostream>

double fast_pow(double a, int n) {
    if (n == 0) return 1;
    if (n < 0) return 1 / fast_pow(a, -n);
    double half = fast_pow(a, n / 2);
    if (n % 2 == 0) return half * half;
    return a * half * half;
}

int main() {
    double a; int n;
    std::cin >> a >> n;
    std::cout << fast_pow(a, n) << std::endl;
    return 0;
}
