#include <iostream>

int ackermann(int m, int n) {
    if (m == 0) return n + 1;
    if (m > 0 && n == 0) return ackermann(m - 1, 1);
    return ackermann(m - 1, ackermann(m, n - 1));
}

int main() {
    int m, n;
    std::cin >> m >> n;
    std::cout << ackermann(m, n) << std::endl;
    return 0;
}
