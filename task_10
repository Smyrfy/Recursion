#include <iostream>

int count_even(int arr[], int size) {
    if (size == 0) return 0;
    int count = (arr[size - 1] % 2 == 0) ? 1 : 0;
    return count + count_even(arr, size - 1);
}

int main() {
    int arr[] = {1, 2, 3, 4, 5, 6};
    std::cout << count_even(arr, 6) << std::endl;
    return 0;
}
