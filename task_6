#include <iostream>
#include <string>

bool is_palindrome(const std::string& s, int start, int end) {
    if (start >= end) return true;
    if (s[start] != s[end]) return false;
    return is_palindrome(s, start + 1, end - 1);
}

int main() {
    std::string s;
    std::cin >> s;
    std::cout << (is_palindrome(s, 0, s.length() - 1) ? "YES" : "NO") << std::endl;
    return 0;
}
