#include <iostream>
#include <string>

void reverse_print(const std::string& s, int index) {
    if (index < 0) return;
    std::cout << s[index];
    reverse_print(s, index - 1);
}

int main() {
    std::string s;
    std::getline(std::cin, s);
    reverse_print(s, s.length() - 1);
    return 0;
}
